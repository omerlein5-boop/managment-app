# Supabase - get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App config
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_COACH_NAME=שם המאמן
NEXT_PUBLIC_GYM_NAME=הסטודיו שלי

# Cancellation policy (hours before session)
NEXT_PUBLIC_CANCELLATION_WINDOW_HOURS=4

# Private lesson booking mode: "auto" | "manual"
NEXT_PUBLIC_PRIVATE_BOOKING_MODE=auto
